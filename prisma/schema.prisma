// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  emailVerified Boolean   @default(false)
  mfaEnabled    Boolean   @default(true)
  mfaVerifiedAt DateTime?
  createdAt     DateTime  @default(now())

  plaidItems        PlaidItem[]
  budgetCategories  BudgetCategory[]
  merchantBudgets   MerchantBudget[]
  verificationCodes VerificationCode[]
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

model PlaidItem {
  id              String   @id @default(cuid())
  userId          String
  accessToken     String
  plaidItemId     String?  // Plaid's item_id from token exchange, used to match webhooks
  institutionId   String
  institutionName String
  cursor          String?
  needsRelink     Boolean  @default(false)
  relinkError     String?
  createdAt       DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  accounts     Account[]

  @@index([userId])
}

enum AccountType {
  depository
  credit
  loan
  investment
  other
}

enum FlowType {
  INCOME
  EXPENSE
  TRANSFER
}

model Account {
  id             String      @id @default(cuid())
  plaidItemId    String
  plaidAccountId String      @unique
  name           String
  officialName   String?
  mask           String?
  type           AccountType
  subtype        String?
  createdAt      DateTime    @default(now())

  plaidItem    PlaidItem     @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([plaidItemId])
}

model Transaction {
  id                 String    @id @default(cuid())
  plaidItemId        String
  plaidTransactionId String    @unique
  accountId          String?
  date               DateTime
  name               String
  merchantName       String?
  amount             Float
  category           String?
  subcategory        String?
  categoryOverride   String?   // User-assigned category that takes precedence over auto-mapped
  flowType           FlowType  @default(EXPENSE)
  flowTypeOverride   FlowType?
  pending            Boolean   @default(false)
  createdAt          DateTime  @default(now())

  plaidItem PlaidItem @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([plaidItemId])
  @@index([accountId])
  @@index([date])
  @@index([category])
  @@index([flowType])
}

enum BudgetCategoryType {
  EXPENSE
  INCOME
}

model BudgetCategory {
  id           String             @id @default(cuid())
  userId       String
  name         String
  type         BudgetCategoryType
  monthlyLimit Float?
  createdAt    DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, type])
  @@index([userId])
}

model MerchantBudget {
  id           String   @id @default(cuid())
  userId       String
  merchantName String
  monthlyLimit Float
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantName])
  @@index([userId])
}
