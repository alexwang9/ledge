# =============================================================================
# Ledge — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values for local development.
# In production (Vercel), set these in: Project → Settings → Environment Variables
# Never commit a populated `.env` file.

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# DATABASE_URL: pooled connection string used by the app at runtime (port 6543).
# DIRECT_URL:   direct connection used by Prisma for migrations (port 5432).
# Both come from Supabase → Project Settings → Database → Connection string.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------------
# AUTH_SECRET: any random 32+ byte secret. Generate with: openssl rand -base64 32
# NEXTAUTH_URL: the canonical app URL (no trailing slash).
AUTH_SECRET="REPLACE_ME_WITH_OPENSSL_RAND_BASE64_32"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Plaid
# -----------------------------------------------------------------------------
# PLAID_ENV: sandbox | development | production
# PLAID_REDIRECT_URI: required for OAuth-based banks. Must be registered in
#   Plaid Dashboard → API → Allowed redirect URIs.
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
PLAID_REDIRECT_URI="http://localhost:3000/oauth"

# -----------------------------------------------------------------------------
# Resend (transactional email)
# -----------------------------------------------------------------------------
# FROM_EMAIL must use a domain verified in the Resend dashboard.
# Until your domain is verified, you can use Resend's sandbox sender
# (onboarding@resend.dev) but it only delivers to your own inbox.
RESEND_API_KEY=""
FROM_EMAIL="Ledge <hello@ledgeflux.com>"

# -----------------------------------------------------------------------------
# Upstash Redis (rate limiting)
# -----------------------------------------------------------------------------
# Optional locally — rate limiting becomes a no-op if these are absent.
# Required in production to enforce per-IP auth limits.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
